# Optional project-scoped Codex config.
# Copy selected sections into .codex/config.toml only after trusting this repo.

project_doc_max_bytes = 65536

# OpenAI developer docs MCP. Useful for current Codex/OpenAI docs lookup.
[mcp_servers.openaiDeveloperDocs]
url = "https://developers.openai.com/mcp"

# Figma remote MCP. Requires Figma authentication.
[mcp_servers.figma]
url = "https://mcp.figma.com/mcp"

# Context7 developer docs MCP. Optional when you need current library docs.
[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]
