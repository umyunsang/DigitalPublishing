{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "background": {
      "page": { "$type": "color", "$value": "#F8F7F3" },
      "surface": { "$type": "color", "$value": "#FFFFFF" }
    },
    "text": {
      "default": { "$type": "color", "$value": "#1F2328" },
      "muted": { "$type": "color", "$value": "#656D76" },
      "inverse": { "$type": "color", "$value": "#FFFFFF" }
    },
    "accent": {
      "primary": { "$type": "color", "$value": "#276749" },
      "secondary": { "$type": "color", "$value": "#B7791F" },
      "danger": { "$type": "color", "$value": "#B42318" }
    },
    "border": {
      "subtle": { "$type": "color", "$value": "#D8DEE4" },
      "strong": { "$type": "color", "$value": "#8C959F" }
    }
  },
  "space": {
    "2": { "$type": "dimension", "$value": "2px" },
    "4": { "$type": "dimension", "$value": "4px" },
    "8": { "$type": "dimension", "$value": "8px" },
    "12": { "$type": "dimension", "$value": "12px" },
    "16": { "$type": "dimension", "$value": "16px" },
    "24": { "$type": "dimension", "$value": "24px" },
    "32": { "$type": "dimension", "$value": "32px" },
    "48": { "$type": "dimension", "$value": "48px" }
  },
  "font": {
    "family": {
      "korean": {
        "$type": "fontFamily",
        "$value": ["Noto Sans KR", "Nanum Gothic", "Apple SD Gothic Neo", "Malgun Gothic", "sans-serif"]
      }
    }
  },
  "size": {
    "type": {
      "caption": { "$type": "dimension", "$value": "12px" },
      "body": { "$type": "dimension", "$value": "16px" },
      "heading": { "$type": "dimension", "$value": "24px" },
      "display": { "$type": "dimension", "$value": "40px" }
    }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "small": { "$type": "dimension", "$value": "4px" },
    "medium": { "$type": "dimension", "$value": "8px" },
    "round": { "$type": "dimension", "$value": "999px" }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": {
        "color": "#1F23281F",
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "0px"
      }
    }
  }
}
